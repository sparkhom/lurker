# Server
PORT=8010
NODE_ENV=development

# SQLite database location
DATABASE_PATH=./data/lurker.db

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=replace-me-with-a-long-random-string

# CORS / dev origin for the Vite dev server.
CORS_ORIGIN=https://irc.local.bradroot.me:5173

# WebAuthn (passkey) configuration.
# RP_ID must match the effective domain the browser sees (no scheme, no port).
# ORIGIN must include scheme + port; comma-separated for multiple (e.g. dev + prod).
WEBAUTHN_RP_ID=irc.local.bradroot.me
WEBAUTHN_RP_NAME=Lurker
WEBAUTHN_ORIGIN=https://irc.local.bradroot.me:5173

# Vue dev server (used by client during npm run dev)
VITE_API_BASE=http://localhost:8010
VITE_DEV_HOST=irc.local.bradroot.me

# Web Push VAPID subject — contact identifier embedded in push JWTs.
# Must be a valid mailto: with a real domain or an https: URL.
# APNs (Safari/iOS) rejects single-label domains like localhost.
VAPID_SUBJECT=mailto:you@example.com

# Contact info embedded in our outbound User-Agent (and CTCP VERSION reply)
# so external service operators can reach you if Lurker misbehaves. May be a
# URL or mailto:. Leave unset to fall back to the upstream project link.
# USER_AGENT_CONTACT=https://lurker.example.com
